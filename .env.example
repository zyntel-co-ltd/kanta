# ============================================================
# Kanta — Environment Variables
# Copy to .env.local and fill in values.
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never in browser
# Required for API routes that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (optional — caching, rate limiting) ──────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (optional — error tracking) ─────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=zyntel
SENTRY_PROJECT=kanta

# ── PostHog (optional — product analytics) ──────────────────
NEXT_PUBLIC_POSTHOG_KEY=

# ── Resend (optional — alert emails) ─────────────────────────
RESEND_API_KEY=

# ── Anthropic (optional — AI features) ───────────────────────
ANTHROPIC_API_KEY=
