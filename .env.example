# ============================================================
# Kanta — Environment Variables
# Copy to .env.local and fill in values.
# ============================================================
# Vercel: Set values WITHOUT surrounding quotes in the dashboard.
# Common mistake: NEXT_PUBLIC_SUPABASE_URL must be the Project URL
#   (e.g. https://xxxxxxxx.supabase.co), NOT the anon key.
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
# URL from Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key from Supabase → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never in browser
# Required for API routes that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (optional — caching, rate limiting) ──────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (optional — error tracking) ─────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=zyntel
SENTRY_PROJECT=kanta

# ── PostHog (optional — product analytics + feature flags) ───
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# When NEXT_PUBLIC_POSTHOG_KEY is unset, boolean flags default to off unless overridden below (see zyntel-playbook/12-projects/kanta/feature-flags.md).
# NEXT_PUBLIC_FLAG_SHOW_AI_INTELLIGENCE=true
# NEXT_PUBLIC_FLAG_SHOW_LRIDS=true
# NEXT_PUBLIC_FLAG_SHOW_RECEPTION_TAB=true
# NEXT_PUBLIC_FLAG_SHOW_REFRIGERATOR_MODULE=true
# NEXT_PUBLIC_FLAG_SHOW_SAMPLE_SCAN=true

# Optional: HMAC secret for anonymized sample/visit display tokens (TAT tabs). Falls back to FACILITY_HASH_SALT or dev default.
# TAT_SAMPLE_TOKEN_SECRET=

# ── Resend (optional — alert emails) ─────────────────────────
RESEND_API_KEY=

# ── Anthropic (optional — AI features) ───────────────────────
ANTHROPIC_API_KEY=

# Legacy env — not used for dashboard module visibility (use PostHog flags above). Kept for older deploy docs only.
NEXT_PUBLIC_PRO_FEATURES=false

# ── LRIDS standalone display board (JWT in URL; 24h expiry) ─────────────────
# Strong random secret (min 16 chars). Required for /lrids/[facilityId]?token=... and /api/lrids/token
LRIDS_TOKEN_SECRET=

# ── Hospital / facility branding (used in header, home dashboard, and LRIDS display board) ──────────
NEXT_PUBLIC_HOSPITAL_NAME=Zyntel Hospital
NEXT_PUBLIC_HOSPITAL_LOGO_URL=
# Default Supabase `hospitals.id` for Zyntel Hospital (Lab Metrics, QC, TAT, API fallbacks). Omit to use repo default.
NEXT_PUBLIC_DEFAULT_FACILITY_ID=

# ── AI Intelligence (Phase 10) ────────────────────────────────────────────────
# App base URL — used by cron jobs to call internal API routes
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Secret to protect cron endpoints from unauthorised calls (any random string)
CRON_SECRET=

# ── Data Flywheel — Legal & Compliance ───────────────────────────────────────
# When set to true, anonymised operational data may be used for model training.
# Requires explicit customer acceptance of the Zyntel ToS (Section 8).
# NEVER set true without customer consent on record.
DATA_FLYWHEEL_ENABLED=false

# Facility ID hashing salt — used when exporting anonymised training datasets.
# Rotate annually. Changing this value re-anonymises all historical exports.
FACILITY_HASH_SALT=
