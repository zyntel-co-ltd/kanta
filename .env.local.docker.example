# Copy to .env.local when using docker-compose Postgres (ENG-93).
# DATABASE_URL is for direct connections (migrations, Prisma-style tools). Adjust host/port if you change docker-compose.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/kanta

# Point the app at the same database if you self-host Supabase-compatible Postgres only:
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
